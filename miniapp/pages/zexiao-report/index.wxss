.report-container {
  height: 100vh;
  background-color: #faf8f4;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.report-nav {
  background-color: #faf8f4;
  flex-shrink: 0;
}
.nav-content {
  display: flex;
  align-items: center;
  height: 44px;
  padding-left: 20rpx;
  padding-right: 20rpx;
}
.nav-back {
  width: 100rpx;
  color: #D4AF37;
  font-size: 32rpx;
  font-weight: bold;
}
.nav-title {
  flex: 1;
  text-align: center;
  color: #1a1814;
  font-size: 32rpx;
  font-weight: bold;
}

.report-header {
  text-align: center;
  padding: 60rpx 40rpx 30rpx;
}

.report-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1814;
}

.report-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.report-body {
  flex: 1;
  height: 0;
  padding: 0 20rpx;
  padding-bottom: 120rpx;
}

/* rich-text 报告样式 */
.report-content {
  padding: 20rpx 0;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.report-content h1 {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1814;
  margin: 40rpx 0 20rpx;
  border-bottom: 2rpx solid #EAEAEA;
  padding-bottom: 16rpx;
  word-break: break-all;
}

.report-content h2 {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1814;
  border-bottom: 1px solid #EAEAEA;
  padding-bottom: 20rpx;
  margin-top: 60rpx;
  word-break: break-all;
}

.report-content h3 {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1814;
  margin-top: 40rpx;
  word-break: break-all;
}

.report-content p {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  margin: 10rpx 0;
  word-break: break-all;
}

.report-content strong {
  color: #D32F2F;
  font-weight: bold;
}

.report-content em {
  font-style: italic;
  color: #666;
}

.report-content ul {
  padding-left: 40rpx;
  margin: 10rpx 0;
  box-sizing: border-box;
}

.report-content li {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  word-break: break-all;
}

.report-content hr {
  border: none;
  border-top: 1px solid #EAEAEA;
  margin: 30rpx 0;
}

.loading-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.loading-text {
  font-size: 32rpx;
  color: #1a1814;
  margin-bottom: 20rpx;
}

.loading-hint {
  font-size: 24rpx;
  color: #999;
}

.error-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.error-text {
  font-size: 28rpx;
  color: #D32F2F;
  margin-bottom: 40rpx;
}

.retry-btn {
  display: inline-block;
  padding: 16rpx 60rpx;
  background-color: #1a1814;
  color: #D4AF37;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.footer-hook {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background-color: #1a1814;
  color: #D4AF37;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 100;
  box-shadow: 0 -10rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* ========== 6维报告卡片样式 ========== */
.dim-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.dim-header {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1814;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0ebe3;
  margin-bottom: 20rpx;
}
.dim-item {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f2ed;
}
.dim-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}
.dim-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}
.dim-value.highlight {
  color: #D4AF37;
  font-weight: bold;
}
.dim-value.safe {
  color: #4CAF50;
  font-weight: bold;
}
.dim-value.warn {
  color: #FF5722;
  font-weight: bold;
}
.fri-score {
  text-align: center;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}
.fri-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #D4AF37;
  line-height: 1;
}
.fri-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}
.plan-card {
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 16rpx 0;
}
.plan-a {
  background: linear-gradient(135deg, #FFF8E1, #FFF3CD);
  border-left: 8rpx solid #D4AF37;
}
.plan-b {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-left: 8rpx solid #4CAF50;
}
.plan-c {
  background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  border-left: 8rpx solid #2196F3;
}
.plan-badge {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.plan-a .plan-badge { color: #B8860B; }
.plan-b .plan-badge { color: #388E3C; }
.plan-c .plan-badge { color: #1565C0; }
.plan-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
  word-break: break-all;
}
.risk-card {
  background: #FFF3E0;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 0;
  border-left: 8rpx solid #FF5722;
}
.risk-header {
  font-size: 28rpx;
  font-weight: bold;
  color: #E64A19;
  margin-bottom: 12rpx;
}
.risk-content {
  font-size: 26rpx;
  color: #BF360C;
  line-height: 1.7;
}
.reflection-card {
  background: #E8F5E9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx 0;
}
.reflection-header {
  font-size: 28rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 12rpx;
}
.reflection-item {
  font-size: 26rpx;
  padding: 8rpx 0;
}
.reflection-item.pass {
  color: #388E3C;
}
.reflection-item.fail {
  color: #D32F2F;
  font-weight: bold;
}
