.entry-container {
  height: 100vh;
  background-color: #1a1814;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
  overflow-y: auto;
}
.brand-area {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 60rpx;
}
.brand-logo {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.brand-name {
  font-size: 56rpx;
  color: #D4AF37;
  font-weight: bold;
  letter-spacing: 4rpx;
}
.brand-sub {
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
}
.brand-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}
.role-section {
  margin-top: 60rpx;
}
.role-title {
  color: #999;
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 30rpx;
}
.role-btn {
  background: #222;
  border: 2rpx solid #D4AF37;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}
.role-emoji {
  font-size: 48rpx;
  margin-right: 24rpx;
}
.role-label {
  color: #D4AF37;
  font-size: 32rpx;
  font-weight: bold;
}
.role-hint {
  color: #888;
  font-size: 24rpx;
  margin-top: 4rpx;
}
.qa-header {
  margin-bottom: 40rpx;
  padding-top: 40rpx;
}
.qa-progress {
  color: #D4AF37;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.qa-title {
  color: #E0E0E0;
  font-size: 36rpx;
  font-weight: bold;
}
.qa-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.qa-opt {
  background: #222;
  border: 2rpx solid #333;
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  color: #E0E0E0;
  font-size: 30rpx;
}
.qa-back {
  color: #D4AF37;
  margin-top: 40rpx;
  font-size: 28rpx;
}
.step2-parent {
  padding-top: 80rpx;
  text-align: center;
}
.parent-icon {
  font-size: 80rpx;
}
.parent-title {
  color: #D4AF37;
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 20rpx;
}
.parent-desc {
  color: #888;
  font-size: 26rpx;
  margin-top: 16rpx;
  padding: 0 40rpx;
}
.parent-actions {
  margin-top: 60rpx;
}
.confirm-card {
  background: #222;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}
.confirm-title {
  color: #D4AF37;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}
.confirm-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #333;
}
.confirm-label {
  color: #888;
  font-size: 28rpx;
}
.confirm-val {
  color: #D4AF37;
  font-size: 28rpx;
}
.action-btn {
  background: linear-gradient(135deg, #D4AF37, #F5D76E);
  color: #1a1814;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}
.action-btn-share {
  background: transparent;
  border: 2rpx solid #00FFCC;
  color: #00FFCC;
  font-weight: normal;
  font-size: 28rpx;
  padding: 20rpx;
}
.share-section {
  margin-top: 20rpx;
  text-align: center;
}
.share-hint {
  color: #666;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.action-btn-share {
  border: none;
  margin: 0;
  padding: 20rpx;
  line-height: normal;
}
.action-btn-share::after {
  border: none;
}