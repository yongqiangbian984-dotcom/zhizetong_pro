<view class="chat-container">
  <view class="nav-bar" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="goBack">‹ 返回</view>
      <view class="nav-title">智择通</view>
      <view class="nav-progress" wx:if="{{completion.total > 0}}">{{completion.total}}%</view>
    </view>
  </view>

  <view class="progress-bar-mini" wx:if="{{completion.total > 0}}">
    <view class="progress-fill" style="width: {{completion.total}}%"></view>
  </view>

  <scroll-view class="msg-list" scroll-y="true" scroll-into-view="{{scrollToId}}" scroll-with-animation="true">
    <view class="msg-item {{item.role === 'user' ? 'my-msg' : 'ai-msg'}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <view class="bubble" user-select="true">{{item.content}}</view>
    </view>
    <view id="msg-bottom"></view>
  </scroll-view>

  <view class="report-btn" wx:if="{{canReport && role !== 'parent'}}" bindtap="goToReport">
    📊 生成择校报告 ({{completion.total}}%)
  </view>

  <view class="complete-tip" wx:if="{{role === 'parent' && completion.total >= 90}}">
    ✅ 孩子的评估已完成 {{completion.total}}%
  </view>

  <view class="input-area" style="padding-bottom: {{keyboardHeight}}px;">
    <input class="input-box" placeholder="说点什么..." placeholder-style="color:#555" value="{{inputValue}}" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" focus="{{focusInput}}" bindblur="onInputBlur" adjust-position="{{false}}" bindkeyboardheightchange="onKeyboardChange" cursor-spacing="10" />
    <view class="send-btn" bindtap="sendMessage">发送</view>
  </view>
</view>
